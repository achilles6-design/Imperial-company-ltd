<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Vanguard Construction Co. — Modern Construction Services</title>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#0b0d10;
      --card:#0f1316;
      --muted:#9aa4ad;
      --accent:#ff7a00; /* orange accent */
      --glass: rgba(255,255,255,0.03);
      --radius:12px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
      background:linear-gradient(180deg,#060708 0%, #0b0d10 100%);
      color:#e6eef6;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      line-height:1.4;
      overflow-y:scroll;
    }

    /* Sticky Navbar */
    header{
      position:sticky;
      top:0;
      z-index:60;
      backdrop-filter: blur(6px);
      background: linear-gradient(180deg, rgba(11,13,16,0.75), rgba(11,13,16,0.45));
      border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .container{
      max-width:1200px;
      margin:0 auto;
      padding:1rem;
    }
    .nav{
      display:flex;
      align-items:center;
      gap:1rem;
      justify-content:space-between;
    }
    .brand{
      display:flex;
      gap:.75rem;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }
    .brand .logo{
      width:44px;
      height:44px;
      border-radius:10px;
      background: linear-gradient(135deg,var(--accent), #ff5b00);
      display:grid;
      place-items:center;
      font-weight:800;
      color:#0b0d10;
      font-size:18px;
      box-shadow: 0 4px 18px rgba(255,122,0,0.12), inset 0 -6px 18px rgba(0,0,0,0.18);
    }
    nav ul{
      display:flex;
      gap:0.5rem;
      list-style:none;
      margin:0;
      padding:0;
      align-items:center;
    }
    nav a{
      color:var(--muted);
      text-decoration:none;
      padding:.6rem .8rem;
      border-radius:8px;
      font-weight:600;
      font-size:14px;
      transition:all .18s ease;
    }
    nav a:hover, nav a.active{
      color:#fff;
      background: linear-gradient(90deg, rgba(255,122,0,0.12), rgba(255,90,0,0.06));
      box-shadow: 0 4px 18px rgba(255,122,0,0.04);
    }

    .cta{
      display:inline-flex;
      align-items:center;
      gap:.6rem;
      padding:.6rem .9rem;
      border-radius:10px;
      background: linear-gradient(90deg,var(--accent), #ff5b00);
      color:#0b0d10;
      font-weight:700;
      text-decoration:none;
      box-shadow: 0 8px 28px rgba(255,122,0,0.12);
      border: none;
      cursor:pointer;
    }

    /* Mobile */
    .hamburger{
      display:none;
      background:transparent;
      border:0;
      color:var(--muted);
      font-size:22px;
      cursor:pointer;
    }

    /* Hero */
    .hero{
      display:grid;
      grid-template-columns:1fr 420px;
      gap:2rem;
      align-items:center;
      padding:3rem 1rem;
    }
    .hero .eyebrow{
      color:var(--accent);
      font-weight:700;
      font-size:13px;
      letter-spacing:.8px;
      text-transform:uppercase;
      margin-bottom:.8rem;
    }
    .hero h1{
      margin:0 0 .6rem 0;
      font-size: clamp(28px, 4vw, 44px);
      line-height:1.02;
      letter-spacing:-0.01em;
      font-weight:800;
      color:#fff;
    }
    .hero p{
      color:var(--muted);
      margin:0 0 1.2rem 0;
      max-width:60ch;
    }
    .hero .actions{display:flex; gap:.8rem; margin-top:1rem}
    .card{
      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
      border-radius:var(--radius);
      padding:1rem;
      border:1px solid rgba(255,255,255,0.03);
      box-shadow: 0 6px 30px rgba(0,0,0,0.6);
    }

    /* Services */
    .services{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:1rem;
      margin-top:1.25rem;
    }
    .service{
      padding:1.15rem;
      border-radius:12px;
      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));
      display:flex;
      flex-direction:column;
      gap:.6rem;
      min-height:110px;
    }
    .service .icon{
      width:44px;
      height:44px;
      border-radius:9px;
      background:rgba(255,122,0,0.12);
      color:var(--accent);
      display:grid;
      place-items:center;
      font-weight:700;
    }
    .service h4{margin:0;color:#fff;margin-top:.3rem}
    .service p{margin:0;color:var(--muted);font-size:14px;}

    /* About */
    .about{
      display:grid;
      grid-template-columns: 1fr 360px;
      gap:1.5rem;
      align-items:center;
      margin-top:1.5rem;
    }
    .about .stats{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:1rem;
    }
    .stat{background:var(--card); padding:1rem;border-radius:10px;text-align:center}
    .stat h3{margin:0;font-size:20px;color:var(--accent)}
    .stat p{margin:0;color:var(--muted);font-size:13px}

    /* Projects */
    .projects-grid{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:1rem;
      margin-top:1rem;
    }
    .project-card{
      position:relative;
      overflow:hidden;
      border-radius:12px;
      min-height:160px;
      background:linear-gradient(180deg,#0b1013,#0f1316);
      border:1px solid rgba(255,255,255,0.03);
    }
    .project-card .meta{
      position:absolute;
      bottom:12px;
      left:12px;
      right:12px;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }
    .project-card .meta h4{margin:0;font-size:15px}
    .project-card .meta p{margin:0;color:var(--muted);font-size:13px}

    /* Contact */
    .contact-grid{
      display:grid;
      grid-template-columns: 1fr 380px;
      gap:1rem;
      margin-top:1.25rem;
    }
    form input, form textarea{
      width:100%;
      padding:.9rem;
      border-radius:10px;
      border:1px solid rgba(255,255,255,0.04);
      background:transparent;
      color:#e8f1fb;
      resize:vertical;
      font-size:14px;
    }
    form label{font-size:13px;color:var(--muted);display:block;margin-bottom:.4rem}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
    .btn-ghost{
      background:transparent;
      color:var(--accent);
      border:1px solid rgba(255,122,0,0.16);
      padding:.75rem 1rem;
      border-radius:10px;
      cursor:pointer;
    }

    footer{
      margin-top:2.5rem;
      padding:2rem 0;
      border-top:1px solid rgba(255,255,255,0.02);
      color:var(--muted);
    }

    /* Responsive */
    @media (max-width:980px){
      .hero{grid-template-columns:1fr}
      .about{grid-template-columns:1fr}
      .contact-grid{grid-template-columns:1fr}
      .projects-grid{grid-template-columns:repeat(2,1fr)}
      .services{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width:720px){
      .container{padding:.7rem}
      nav ul{display:none}
      .hamburger{display:inline-flex}
      .hero { padding:2rem .6rem}
      .projects-grid{grid-template-columns:1fr}
      .service{min-height:120px}
    }

    /* Mobile nav panel */
    .mobile-panel{
      position:fixed;
      inset:0;
      background:linear-gradient(180deg, rgba(7,8,10,0.82), rgba(7,8,10,0.9));
      display:none;
      z-index:100;
      padding:5rem 1rem 2rem;
      overflow:auto;
    }
    .mobile-panel.active{display:block}
    .mobile-panel nav ul{display:flex; flex-direction:column; gap:.4rem}
    .mobile-panel .mobile-cta{margin-top:1rem;display:flex;gap:.6rem}
  </style>
</head>

<script>
  // Smooth scroll & active link tracking
  document.querySelectorAll('a.navlink').forEach(a=>{
    a.addEventListener('click', (e)=>{
      const href = a.getAttribute('href');
      if(href && href.startsWith('#')){
        e.preventDefault();
        const el = document.querySelector(href);
        if(el) el.scrollIntoView({behavior:'smooth', block:'start'});
        // close mobile if open
        closeMobile();
      }
    });
  });

  const sections = Array.from(document.querySelectorAll('main section, header'));
  const navLinks = Array.from(document.querySelectorAll('.navlink'));

  function onScroll(){
    let found=false;
    for(const s of sections){
      const rect = s.getBoundingClientRect();
      if(rect.top <= 120 && rect.bottom > 120){
        const id = s.id ? '#'+s.id : null;
        navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === id));
        found=true;
        break;
      }
    }
    if(!found){
      navLinks.forEach(l => l.classList.remove('active'));
      document.querySelector('.navlink[href="#home"]').classList.add('active');
    }
  }
  window.addEventListener('scroll', onScroll, {passive:true});
  onScroll();

  // Mobile nav
  function toggleMobile(){
    const p = document.getElementById('mobilePanel');
    const active = p.classList.toggle('active');
    p.setAttribute('aria-hidden', !active);
  }
  function closeMobile(){
    const p = document.getElementById('mobilePanel');
    p.classList.remove('active');
    p.setAttribute('aria-hidden', 'true');
  }

  // Contact form handlers (placeholder)
  function submitForm(e){
    e.preventDefault();
    const name = document.getElementById('name').value || 'Client';
    alert('Thanks, ' + name + '! Your inquiry has been submitted. We will contact you shortly.');
    resetForm();
    // In production: send via fetch to a backend endpoint
  }
  function resetForm(){
    document.querySelector('form').reset();
  }

  // Simple project modal
  function openProject(title, desc){
    document.getElementById('projTitle').textContent = title;
    document.getElementById('projDesc').textContent = desc;
    document.getElementById('projectModal').style.display = 'flex';
  }
  function closeProject(){
    document.getElementById('projectModal').style.display = 'none';
  }
  function openInNew(){
    // Placeholder: in a multi-page version this would open the dedicated project page
    closeProject();
    alert('Open full project page (placeholder)');
  }

  // Footer year
  document.getElementById('year').textContent = new Date().getFullYear();

  // Accessibility: close modal with Esc
  document.addEventListener('keydown',(e)=>{
    if(e.key === 'Escape'){
      closeProject();
      closeMobile();
    }
  });

</script>
</body>
